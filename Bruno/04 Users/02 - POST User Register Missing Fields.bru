meta {
  name: 02 - POST User Register Missing Fields
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "incomplete@example.com"
  }
}

assert {
  res.status: eq 400
  res.body.error: eq All fields are required
}

settings {
  encodeUrl: true
  timeout: 0
}
