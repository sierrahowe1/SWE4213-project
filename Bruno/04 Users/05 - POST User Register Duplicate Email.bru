meta {
  name: 05 - POST User Register Duplicate Email
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "first_name": "Bruno",
    "last_name": "Duplicate",
    "email": "bruno.user.{{runId}}@example.com",
    "password": "password123"
  }
}

assert {
  res.status: eq 400
  res.body.error: eq Email is already registered
}

settings {
  encodeUrl: true
  timeout: 0
}
