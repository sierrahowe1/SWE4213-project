meta {
  name: 03 - POST User Register Invalid Email
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "first_name": "Bad",
    "last_name": "Email",
    "email": "not-an-email",
    "password": "password123"
  }
}

assert {
  res.status: eq 400
  res.body.error: eq Invalid email format
}

settings {
  encodeUrl: true
  timeout: 0
}
