meta {
  name: 08 - POST Review Duplicate
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/reviews
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "user_id": 1,
    "book_id": 1,
    "rating": 3,
    "review_text": "Trying to review the same book again"
  }
}

assert {
  res.status: eq 409
  res.body.error: eq User has already reviewed this book
}

settings {
  encodeUrl: true
  timeout: 0
}
