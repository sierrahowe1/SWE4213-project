meta {
  name: 10 - PUT Review Nonexistent
  type: http
  seq: 10
}

put {
  url: {{baseUrl}}/api/reviews/999999
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "rating": 3
  }
}

assert {
  res.status: eq 404
  res.body.error: eq Review not found
}

settings {
  encodeUrl: true
  timeout: 0
}
