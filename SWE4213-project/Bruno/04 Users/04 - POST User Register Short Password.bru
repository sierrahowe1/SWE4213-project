meta {
  name: 04 - POST User Register Short Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "first_name": "Short",
    "last_name": "Pass",
    "email": "short@example.com",
    "password": "abc"
  }
}

assert {
  res.status: eq 400
  res.body.error: eq Password must be at least 8 characters in length
}

settings {
  encodeUrl: true
  timeout: 0
}
