meta {
  name: 07 - POST User Login Wrong Password
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "bruno.user.{{runId}}@example.com",
    "password": "wrongpassword"
  }
}

assert {
  res.status: eq 401
  res.body.error: eq Invalid email or password
}

settings {
  encodeUrl: true
  timeout: 0
}
