meta {
  name: 03 - GET Book By Created ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/books/{{createdBookId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  const body = res.getBody();
  expect(String(body.book_id)).to.equal(String(bru.getEnvVar("createdBookId")));
}

settings {
  encodeUrl: true
  timeout: 0
}
